{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/auth/login",    "destination": "/api/auth/login.py" },
    { "source": "/api/auth/callback", "destination": "/api/auth/callback.py" },
    { "source": "/api/sync",          "destination": "/api/sync.py" },
    { "source": "/api/insights",      "destination": "/api/insights.py" },
    { "source": "/api/transactions",  "destination": "/api/transactions.py" }
  ]
}
